<idea-plugin>
    <id>com.codex.assistant</id>
    <name>Codex Assistant</name>
    <vendor email="support@example.com">Codex Assistant</vendor>

    <description><![CDATA[
        Unified IDE agent shell for local CLI engines.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                id="Codex Chat"
                factoryClass="com.codex.assistant.toolwindow.AgentToolWindowFactory"
                anchor="right"
                canCloseContents="false"/>

        <applicationConfigurable
                parentId="tools"
                instance="com.codex.assistant.settings.AgentSettingsConfigurable"
                id="com.codex.assistant.settings"
                displayName="Codex Assistant"/>
    </extensions>

    <actions>
        <action id="com.codex.assistant.QuickOpen"
                class="com.codex.assistant.actions.QuickOpenAction"
                text="Open Codex Assistant"
                description="Quick open Codex Assistant tool window">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl K"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta K"/>
        </action>
    </actions>
</idea-plugin>

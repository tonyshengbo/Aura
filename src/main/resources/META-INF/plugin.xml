<idea-plugin>
    <id>com.codex.assistant</id>
    <name>%plugin.name</name>
    <vendor email="support@example.com">Codex Assistant</vendor>

    <resource-bundle>messages.CodexBundle</resource-bundle>
    <description>%plugin.description</description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                id="Codex Chat"
                factoryClass="com.codex.assistant.toolwindow.bootstrap.AgentToolWindowFactory"
                anchor="right"
                canCloseContents="false"/>

    </extensions>

    <actions>
        <action id="com.codex.assistant.QuickOpen"
                class="com.codex.assistant.actions.QuickOpenAction"
                text="%action.open.text"
                description="%action.open.description">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl K"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta K"/>
        </action>
    </actions>
</idea-plugin>
